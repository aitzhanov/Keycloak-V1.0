<odoo>

    <!-- ================================================================
         Audit Log — list view
    ================================================================= -->
    <record id="view_keycloak_audit_log_list" model="ir.ui.view">
        <field name="name">auth.keycloak.audit.log.list</field>
        <field name="model">auth.keycloak.audit.log</field>
        <field name="arch" type="xml">
            <list string="Keycloak Audit Log" create="false" edit="false" delete="false">
                <field name="create_date" string="Timestamp" widget="datetime"/>
                <field name="event_type"/>
                <field name="result"
                       decoration-success="result == 'success'"
                       decoration-danger="result == 'denied'"
                       decoration-warning="result == 'error'"/>
                <field name="user_id"/>
                <field name="oauth_uid"/>
                <field name="provider_id"/>
                <field name="ip"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         Audit Log — form view (read-only)
    ================================================================= -->
    <record id="view_keycloak_audit_log_form" model="ir.ui.view">
        <field name="name">auth.keycloak.audit.log.form</field>
        <field name="model">auth.keycloak.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="event_type"/>
                            <field name="result"/>
                            <field name="create_date" string="Timestamp"/>
                        </group>
                        <group string="Identity">
                            <field name="user_id"/>
                            <field name="oauth_uid"/>
                            <field name="provider_id"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="ip" string="IP Address"/>
                        <field name="reason" string="Reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         Search view
    ================================================================= -->
    <record id="view_keycloak_audit_log_search" model="ir.ui.view">
        <field name="name">auth.keycloak.audit.log.search</field>
        <field name="model">auth.keycloak.audit.log</field>
        <field name="arch" type="xml">
            <search string="Search Audit Log">
                <field name="user_id"/>
                <field name="oauth_uid" string="OAuth UID (sub)"/>
                <field name="provider_id"/>
                <field name="ip"/>
                <filter name="success" string="Success" domain="[('result','=','success')]"/>
                <filter name="denied" string="Denied" domain="[('result','=','denied')]"/>
                <filter name="error" string="Error" domain="[('result','=','error')]"/>
                <separator/>
                <filter name="login_success" string="Login Success"
                        domain="[('event_type','=','login_success')]"/>
                <filter name="login_denied" string="Login Denied"
                        domain="[('event_type','=','login_denied')]"/>
                <filter name="jit_create" string="JIT Created"
                        domain="[('event_type','=','jit_create')]"/>
                <filter name="backchannel_logout" string="Back-Channel Logout"
                        domain="[('event_type','=','backchannel_logout')]"/>
                <separator/>
                <filter name="group_event" string="Event Type"
                        context="{'group_by': 'event_type'}"/>
                <filter name="group_result" string="Result"
                        context="{'group_by': 'result'}"/>
                <filter name="group_provider" string="Provider"
                        context="{'group_by': 'provider_id'}"/>
                <filter name="group_user" string="User"
                        context="{'group_by': 'user_id'}"/>
                <filter name="group_day" string="Day"
                        context="{'group_by': 'create_date:day'}"/>
            </search>
        </field>
    </record>

    <!-- ================================================================
         Action
    ================================================================= -->
    <record id="action_keycloak_audit_log" model="ir.actions.act_window">
        <field name="name">Keycloak Audit Log</field>
        <field name="res_model">auth.keycloak.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_keycloak_audit_log_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No audit events yet.
            </p>
            <p>Events are recorded automatically on every SSO login, logout, and JIT user creation.</p>
        </field>
    </record>

    <!-- ================================================================
         Menu — Settings > Keycloak > Audit Log
    ================================================================= -->
    <menuitem id="menu_keycloak_root"
              name="Keycloak"
              parent="base_setup.action_general_configuration"
              sequence="90"/>

    <menuitem id="menu_keycloak_audit_log"
              name="Audit Log"
              parent="menu_keycloak_root"
              action="action_keycloak_audit_log"
              sequence="10"
              groups="base.group_system"/>

</odoo>
